{
    admin 0.0.0.0:2019 {
        origins host.docker.internal:2019 localhost:2019 127.0.0.1:2019
    }
}

# Managed by default-site — do not edit manually.

*.lk-pc.localdomain, lk-pc.localdomain {
	tls internal

	log

	@postgres host postgres
	handle @postgres {
		reverse_proxy localhost:1234
	}

	@asd host asd
	handle @asd {
		reverse_proxy fdsa
	}

	handle {
		reverse_proxy localhost:3080
	}
}
